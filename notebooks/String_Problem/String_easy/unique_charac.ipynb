      ]
     },
     "execution_count": 3,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def first_unique(s):\n",
    "\n",
    "    freq={}\n",
    "\n",
    "    for ch in s:\n",
    "        freq[ch]=freq.get(ch,0)+1\n",
    "\n",
    "    for i, ch in enumerate(s):\n",
    "        if freq[ch]==1:\n",
    "            return i\n",
    "\n",
    "    return -1\n",
    "\n",
    "first_unique(\"level\")"
   ]
  }
 ],
